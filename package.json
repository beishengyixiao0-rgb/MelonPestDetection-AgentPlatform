  {
  "scripts": {
    "dev": "npm run services:up && concurrently -n backend,frontend -c green,yellow \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && .venv\\Scripts\\python.exe -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "npm --prefix frontend run dev",
    "services:up": "docker compose up -d",
    "services:down": "docker compose down"
  },
    "devDependencies": {
      "concurrently": "^9.1.0"
    }
  }